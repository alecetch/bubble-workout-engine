{
  "name": "bubble-workout-mobile",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "find src -name '*.test.ts' ! -name '*.unit.test.ts' | sort | xargs tsx --test",
    "test:unit": "find src -name '*.test.ts' ! -name '*.unit.test.ts' | sort | xargs tsx --test",
    "test:components": "vitest run",
    "test:components:watch": "vitest",
    "test:all": "npm run test && npm run test:components"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-community/datetimepicker": "^9.1.0",
