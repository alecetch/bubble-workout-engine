# Doc Admin Board — copy to .env and fill in values

# Port for this admin tool (default 3001, avoids clash with main API on 3000)
DOC_ADMIN_PORT=3001

# Postgres connection string for the SEPARATE doc_admin database
# See README for setup instructions
DOC_ADMIN_DB_URL=postgresql://workout:workout@localhost:5432/doc_admin

# Absolute path to the docs/ directory in this repo
# Defaults to ../docs relative to admin-docs/ if not set
# DOCS_ROOT=/absolute/path/to/bubble-workout-engine/docs
