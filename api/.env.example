# Runtime
NODE_ENV=development
PORT=3000

# Local Postgres (docker-compose)
PGHOST=db
PGPORT=5432
PGUSER=app
PGPASSWORD=app
PGDATABASE=app
PGPOOL_MAX=10

# Deployed Postgres (Fly / managed)
# Prefer DATABASE_URL in staging/production
DATABASE_URL=

# App secrets
ENGINE_KEY=change-me
INTERNAL_API_TOKEN=change-me
JWT_SECRET=<min-32-char-random-string>
JWT_ISSUER=workout-engine
# Optional overrides (defaults shown):
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_DAYS=30

# Local MinIO (development)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/media-assets

# Deployed object storage (staging/production)
# S3_PUBLIC_BASE_URL=https://cdn.example.com/media-assets
# S3_BUCKET=media-assets
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
